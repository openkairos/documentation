          <tr><th>Scope</th><th>Description</th></tr>
        </thead>
        <tbody>
          <tr><td><code>users:read</code></td><td>Read users and profile data.</td></tr>
          <tr><td><code>users:write</code></td><td>Create and update users.</td></tr>
          <tr><td><code>billing:read</code></td><td>Read plans, invoices, and usage.</td></tr>
          <tr><td><code>billing:write</code></td><td>Create and manage subscriptions.</td></tr>
        </tbody>
      </table>
    </div>
  </section>

