<script>
  (function () {
    const body = document.body;
    const menuToggle = document.getElementById('menu-toggle');
    const sidebar = document.getElementById('sidebar-nav');
    const overlay = document.getElementById('mobile-overlay');
    const navLinks = Array.from(document.querySelectorAll('.menu__link[href^="#"]'));
    const collapsibleTriggers = Array.from(
      document.querySelectorAll('.menu__list-item-collapsible .menu__link--sublist, .menu__list-item-collapsible .menu__caret')
    );

    function closeSidebar() {
      body.classList.remove('nav-open');
      sidebar.classList.remove('open');
      overlay.classList.remove('visible');
      menuToggle.setAttribute('aria-expanded', 'false');
    }

    function openSidebar() {
      body.classList.add('nav-open');
      sidebar.classList.add('open');
      overlay.classList.add('visible');
      menuToggle.setAttribute('aria-expanded', 'true');
    }

    menuToggle.addEventListener('click', function () {
      const isOpen = sidebar.classList.contains('open');
      if (isOpen) {
        closeSidebar();
        return;
      }
      openSidebar();
    });

    overlay.addEventListener('click', closeSidebar);

    collapsibleTriggers.forEach(function (trigger) {
      trigger.addEventListener('click', function (event) {
        const listItem = trigger.closest('.menu__list-item');
        if (!listItem) {
          return;
        }

        event.preventDefault();
        listItem.classList.toggle('menu__list-item--collapsed');
      });
    });

    navLinks.forEach(function (link) {
      link.addEventListener('click', function () {
        navLinks.forEach(function (item) {
          item.classList.remove('menu__link--active');
        });
        link.classList.add('menu__link--active');

        let parentItem = link.closest('.menu__list-item');
        while (parentItem) {
          parentItem.classList.remove('menu__list-item--collapsed');
          parentItem = parentItem.parentElement ? parentItem.parentElement.closest('.menu__list-item') : null;
        }

        if (window.matchMedia('(max-width: 840px)').matches) {
          closeSidebar();
        }
      });
    });

    const sections = Array.from(document.querySelectorAll('main section[id]'));
    const observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) {
          return;
        }
        const id = entry.target.getAttribute('id');
        navLinks.forEach(function (link) {
          const isActive = link.getAttribute('href') === '#' + id;
          link.classList.toggle('menu__link--active', isActive);
        });
      });
    }, {
      rootMargin: '-20% 0px -70% 0px',
      threshold: 0
    });

    sections.forEach(function (section) {
      observer.observe(section);
    });
  }());
</script>
