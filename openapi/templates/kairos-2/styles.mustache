<style>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&display=swap');

  :root {
    --ifm-color-primary: #ff343a;
    --ifm-color-primary-dark: #e62f34;
    --ifm-color-primary-darker: #d92c31;
    --ifm-color-primary-light: #ff4c52;
    --ifm-link-color: #d92c31;
    --ifm-color-emphasis-100: #f5f6f7;
    --ifm-color-emphasis-200: #ebedf0;
    --ifm-color-emphasis-300: #dadde1;
    --ifm-color-emphasis-700: #606770;
    --ifm-color-emphasis-900: #1c1e21;
    --ifm-background-color: #ffffff;
    --ifm-font-family-base: 'Manrope', sans-serif;
    --ifm-font-family-monospace: 'Fira Code', monospace;
    --ifm-font-weight-semibold: 600;
    --ifm-transition-fast: 200ms;
    --ifm-transition-timing-default: ease;
    --ifm-menu-color: #444950;
    --ifm-menu-color-active: var(--ifm-color-primary-darker);
    --ifm-menu-color-background-active: rgba(217, 44, 49, 0.1);
    --ifm-menu-color-background-hover: var(--ifm-color-emphasis-100);
    --ifm-menu-link-padding-vertical: 0.375rem;
    --ifm-menu-link-padding-horizontal: 0.75rem;
    --ifm-navbar-height: 3.75rem;
    --ifm-toc-border-color: var(--ifm-color-emphasis-200);
    --ifm-scrollbar-size: 7px;
    --ifm-scrollbar-track-background-color: #f1f2f4;
    --ifm-scrollbar-thumb-background-color: #c3c7ce;
    --ifm-scrollbar-thumb-hover-background-color: #a4acb8;
    --doc-sidebar-width: 320px;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    font-family: var(--ifm-font-family-base);
    background: var(--ifm-background-color);
    color: var(--ifm-color-emphasis-900);
  }

  body.nav-open {
    overflow: hidden;
  }

  .menu-toggle {
    display: none;
    position: fixed;
    top: 14px;
    right: 14px;
    z-index: 12;
    border: 1px solid var(--ifm-color-emphasis-300);
    background: #fff;
    color: var(--ifm-color-emphasis-900);
    border-radius: 10px;
    padding: 8px 12px;
    font: inherit;
    font-weight: 600;
  }

  .layout {
    display: grid;
    grid-template-columns: var(--doc-sidebar-width) 1fr;
    min-height: 100vh;
  }

  .docSidebarContainer {
    border-right: 1px solid var(--ifm-color-emphasis-200);
    background: #fcfcfd;
    width: var(--doc-sidebar-width);
    transition: width var(--ifm-transition-fast) ease;
    clip-path: inset(0);
  }

  .sidebarViewport {
    position: sticky;
    top: 0;
    height: 100vh;
    max-height: 100vh;
    overflow-y: auto;
    padding: 16px 10px 20px;
  }

  .menu {
    font-weight: var(--ifm-font-weight-semibold);
    overflow-x: hidden;
  }

  .menu__list {
    list-style: none;
    margin: 0;
    padding-left: 0;
  }

  .menu__list .menu__list {
    flex: 0 0 100%;
    margin-top: 0.25rem;
    padding-left: var(--ifm-menu-link-padding-horizontal);
  }

  .menu__list-item:not(:first-child) {
    margin-top: 0.25rem;
  }

  .menu__list-item--collapsed .menu__list {
    height: 0;
    overflow: hidden;
  }

  .menu__list-item--collapsed .menu__caret:before {
    transform: rotate(90deg);
  }

  .menu__list-item-collapsible {
    border-radius: 0.25rem;
    display: flex;
    flex-wrap: wrap;
    position: relative;
    transition: background var(--ifm-transition-fast) var(--ifm-transition-timing-default);
  }

  .menu__list-item-collapsible:hover {
    background: var(--ifm-menu-color-background-hover);
  }

  .menu__list-item-collapsible .menu__link--active,
  .menu__list-item-collapsible .menu__link:hover {
    background: none !important;
  }

  .menu__link,
  .menu__caret {
    align-items: center;
    border-radius: 0.25rem;
    display: flex;
    transition: background var(--ifm-transition-fast) var(--ifm-transition-timing-default);
  }

  .menu__link:hover,
  .menu__caret:hover {
    background: var(--ifm-menu-color-background-hover);
  }

  .menu__link {
    color: var(--ifm-menu-color);
    flex: 1;
    line-height: 1.25;
    padding: var(--ifm-menu-link-padding-vertical) var(--ifm-menu-link-padding-horizontal);
    border: 0;
    background: none;
    font: inherit;
    text-align: left;
    cursor: pointer;
    text-decoration: none;
    font-size: 0.93rem;
    min-height: 32px;
  }

  .menu__link:hover {
    color: var(--ifm-menu-color);
    text-decoration: none;
  }

  .menu__link--active,
  .menu__link--active:hover {
    color: var(--ifm-menu-color-active);
  }

  .menu__link--active:not(.menu__link--sublist) {
    background-color: var(--ifm-menu-color-background-active);
  }

  .menu__caret {
    background: none;
    border: 0;
    cursor: pointer;
    padding: var(--ifm-menu-link-padding-vertical) var(--ifm-menu-link-padding-horizontal);
  }

  .menu__caret:before {
    content: "";
    width: 1.25rem;
    height: 1.25rem;
    opacity: 0.7;
    transform: rotate(180deg);
    transition: transform var(--ifm-transition-fast) linear;
    background: currentColor;
    clip-path: polygon(25% 32%, 50% 58%, 75% 32%, 82% 39%, 50% 72%, 18% 39%);
  }

  .content {
    overflow-x: hidden;
    padding: 28px clamp(20px, 4vw, 56px) 72px;
    max-width: none;
    width: 100%;
  }

  .eyebrow {
    margin: 0 0 6px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--ifm-color-primary-darker);
  }

  h1 {
    margin: 0;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.1;
  }

  .lead {
    margin: 14px 0 24px;
    max-width: 72ch;
    font-size: 17px;
    line-height: 1.6;
    color: #4f5d75;
  }

  section {
    margin-top: 44px;
    scroll-margin-top: 18px;
  }

  section h2 {
    margin: 0 0 14px;
    font-size: clamp(24px, 3.5vw, 32px);
    line-height: 1.2;
  }

  .anchor {
    scroll-margin-top: calc(var(--ifm-navbar-height) + 0.5rem);
  }

  .hash-link {
    color: var(--ifm-link-color);
    display: inline-block;
    opacity: 0;
    padding-left: 0.5rem;
    font-weight: 400;
    transition: opacity var(--ifm-transition-fast) var(--ifm-transition-timing-default);
    text-decoration: none;
  }

  .hash-link:visited,
  .hash-link:hover,
  .hash-link:focus {
    color: var(--ifm-link-color);
    text-decoration: none;
  }

  .hash-link::before {
    content: "#";
  }

  .anchor:hover > .hash-link,
  .hash-link:focus {
    opacity: 1;
  }

  .card {
    border: 1px solid var(--ifm-color-emphasis-200);
    border-radius: 14px;
    background: #fff;
    padding: 20px;
    margin-bottom: 14px;
    box-shadow: 0 1px 1px rgba(0, 0, 0, 0.02);
  }

  .api-operation {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 20px;
    align-items: start;
  }

  .api-operation__main {
    min-width: 0;
  }

  .api-operation__aside {
    position: sticky;
    top: 84px;
    display: grid;
    gap: 12px;
  }

  .example-panel {
    border: 1px solid var(--ifm-color-emphasis-200);
    border-radius: 12px;
    background: #fff;
    overflow: hidden;
  }

  .example-panel__header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid var(--ifm-color-emphasis-200);
    padding: 10px 12px;
    background: #f8f9fb;
  }

  .example-panel__header h3 {
    margin: 0;
    font-size: 14px;
    line-height: 1.25;
  }

  .code-tabs {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .code-tab {
    border: 1px solid var(--ifm-color-emphasis-300);
    border-radius: 999px;
    background: #fff;
    color: var(--ifm-color-emphasis-800);
    font-family: var(--ifm-font-family-monospace);
    font-size: 12px;
    padding: 3px 10px;
    cursor: pointer;
  }

  .code-tab.is-active {
    border-color: var(--ifm-color-primary-darker);
    color: var(--ifm-color-primary-darker);
    background: rgba(217, 44, 49, 0.08);
  }

  .copy-example-btn {
    border: 1px solid var(--ifm-color-emphasis-300);
    border-radius: 8px;
    background: #fff;
    color: var(--ifm-color-emphasis-800);
    font-size: 12px;
    font-weight: 700;
    padding: 5px 10px;
    cursor: pointer;
    line-height: 1;
  }

  .copy-example-btn.is-copied {
    border-color: #2e8555;
    color: #2e8555;
    background: rgba(46, 133, 85, 0.08);
  }

  .code-pane {
    display: none;
  }

  .code-pane.is-active {
    display: block;
  }

  .endpoint {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    font-family: var(--ifm-font-family-monospace);
    font-size: 13px;
  }

  .method {
    border-radius: 999px;
    padding: 3px 8px;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: #fff;
  }

  .method.get { background: #2e8555; }
  .method.post { background: #3578e5; }
  .method.delete { background: #d93939; }

  pre {
    margin: 12px 0 0;
    border-radius: 12px;
    border: 1px solid #1d2128;
    background: #1f2530;
    color: #e6edf3;
    font-family: var(--ifm-font-family-monospace);
    font-size: 13px;
    line-height: 1.55;
    overflow-x: auto;
    padding: 14px;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }

  .table-wrap {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 560px;
  }

  th,
  td {
    border: 1px solid var(--ifm-color-emphasis-200);
    padding: 10px 12px;
    text-align: left;
    font-size: 14px;
    vertical-align: top;
  }

  th {
    background: #f8f9fb;
    font-weight: 700;
  }

  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    z-index: 9;
  }

  .mobile-overlay.visible {
    display: block;
  }

  @media (pointer: fine) {
    .thin-scrollbar {
      scrollbar-width: thin;
    }

    .thin-scrollbar::-webkit-scrollbar {
      width: var(--ifm-scrollbar-size);
      height: var(--ifm-scrollbar-size);
    }

    .thin-scrollbar::-webkit-scrollbar-track {
      background: var(--ifm-scrollbar-track-background-color);
      border-radius: 10px;
    }

    .thin-scrollbar::-webkit-scrollbar-thumb {
      background: var(--ifm-scrollbar-thumb-background-color);
      border-radius: 10px;
    }

    .thin-scrollbar::-webkit-scrollbar-thumb:hover {
      background: var(--ifm-scrollbar-thumb-hover-background-color);
    }
  }

  @media (max-width: 1024px) {
    .layout {
      grid-template-columns: 280px 1fr;
    }
  }

  @media (max-width: 840px) {
    .menu-toggle {
      display: inline-flex;
      align-items: center;
    }

    .layout {
      display: block;
    }

    .docSidebarContainer {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: min(84vw, 320px);
      transform: translateX(-100%);
      transition: transform 0.22s ease;
      z-index: 10;
      box-shadow: 2px 0 24px rgba(0, 0, 0, 0.16);
    }

    .docSidebarContainer.open {
      transform: translateX(0);
    }

    .content {
      padding: 58px 16px 56px;
    }

    .api-operation {
      grid-template-columns: 1fr;
    }

    .api-operation__aside {
      position: static;
    }

    .table-wrap {
      margin-left: -4px;
      margin-right: -4px;
    }
  }
</style>
